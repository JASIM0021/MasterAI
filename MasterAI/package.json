{
  "name": "masterai",
  "version": "1.0.0",
  "main": "index",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "set-ip": "node set-current-ip.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "aab": "npx react-native build-android --mode=release",
    "build-clean": "cd android && ./gradlew clean && cd .. ",
    "fast-run": "react-native run-android --active-arch-only",
    "buildDebug": "cd android && ./gradlew assembleDebug",
    "build": "cd android && ./gradlew assembleRelease",
    "apk": "adb install -r android/app/release/app-release.apk",
    "installapk": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "debug": "adb  install -r android/app/build/outputs/apk/debug/app-debug.apk",
    "buildandInstall": "npm run build && npm run installapk",
    "report-android": "cd android && ./gradlew signingReport && cd ..",
    "release": "npx react-native build-android --mode=release",
    "easBuild": "eas build -p android --profile release",
    "codePush": "appcenter codepush release-react -a maasterrai-gmail.com/Master-AI  -d Staging",
    "eas-android": "eas update --channel masterai-prod --message 'new Update' --platform  android",
    "eas-ios": "eas update --channel masterai-prod --message 'new Update' --platform  ios"
  },
  "dependencies": {
